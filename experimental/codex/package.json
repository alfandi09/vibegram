{
    "name": "@vibegram/codex",
    "version": "0.1.0",
    "description": "Codex ChatGPT plugin for VibeGram — connects Telegram bots to ChatGPT via Codex session token",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build:cjs": "tsc --project tsconfig.json",
        "build:esm": "tsc --project tsconfig.esm.json",
        "postbuild": "node scripts/postbuild.js",
        "build": "npm run build:cjs && npm run build:esm",
        "test:live": "npm run build && npx --no-install ts-node examples/live-telegram-bot.ts",
        "test": "npx --no-install vitest run tests",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "vibegram",
        "telegram",
        "chatgpt",
        "openai",
        "gpt",
        "plugin",
        "bot"
    ],
    "author": "Alfa",
    "license": "ISC",
    "peerDependencies": {
        "vibegram": ">=1.2.0"
    },
    "dependencies": {
        "axios": "^1.15.2"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "typescript": "^6.0.2",
        "vibegram": "file:../.."
    }
}
