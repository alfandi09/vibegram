{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "lib": ["ES2022"],
        "types": ["node"],
        "outDir": "./dist/esm",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "rootDir": "./src"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "examples"]
}
