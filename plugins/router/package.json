{
    "name": "@vibegram/router",
    "version": "0.1.0",
    "description": "Declarative route-key middleware for VibeGram bots",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build:cjs": "tsc --project tsconfig.json",
        "build:esm": "tsc --project tsconfig.esm.json",
        "write:package-markers": "node scripts/postbuild.js",
        "build": "npm run build:cjs && npm run build:esm && npm run write:package-markers",
        "test": "npx --no-install vitest run tests",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "vibegram",
        "telegram",
        "bot",
        "router",
        "middleware"
    ],
    "author": "Alfa",
    "license": "ISC",
    "peerDependencies": {
        "vibegram": ">=2.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "typescript": "^6.0.2",
        "vitest": "^3.2.4",
        "vibegram": "file:../.."
    }
}
