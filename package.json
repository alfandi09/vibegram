{
    "name": "vibegram",
    "version": "1.2.1",
    "description": "Modern, production-ready Telegram Bot Framework for Node.js — Broad Bot API v9.6 coverage with built-in middleware, sessions, and webhook adapters",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        },
        "./adapters": {
            "import": "./dist/esm/adapters.js",
            "require": "./dist/cjs/adapters.js",
            "types": "./dist/types/adapters.d.ts"
        },
        "./bot": {
            "import": "./dist/esm/bot.js",
            "require": "./dist/cjs/bot.js",
            "types": "./dist/types/bot.d.ts"
        },
        "./cache": {
            "import": "./dist/esm/cache.js",
            "require": "./dist/cjs/cache.js",
            "types": "./dist/types/cache.d.ts"
        },
        "./client": {
            "import": "./dist/esm/client.js",
            "require": "./dist/cjs/client.js",
            "types": "./dist/types/client.d.ts"
        },
        "./composer": {
            "import": "./dist/esm/composer.js",
            "require": "./dist/cjs/composer.js",
            "types": "./dist/types/composer.d.ts"
        },
        "./context": {
            "import": "./dist/esm/context.js",
            "require": "./dist/cjs/context.js",
            "types": "./dist/types/context.d.ts"
        },
        "./conversation": {
            "import": "./dist/esm/conversation.js",
            "require": "./dist/cjs/conversation.js",
            "types": "./dist/types/conversation.d.ts"
        },
        "./errors": {
            "import": "./dist/esm/errors.js",
            "require": "./dist/cjs/errors.js",
            "types": "./dist/types/errors.d.ts"
        },
        "./filters": {
            "import": "./dist/esm/filters.js",
            "require": "./dist/cjs/filters.js",
            "types": "./dist/types/filters.d.ts"
        },
        "./i18n": {
            "import": "./dist/esm/i18n.js",
            "require": "./dist/cjs/i18n.js",
            "types": "./dist/types/i18n.d.ts"
        },
        "./inline": {
            "import": "./dist/esm/inline.js",
            "require": "./dist/cjs/inline.js",
            "types": "./dist/types/inline.d.ts"
        },
        "./logger": {
            "import": "./dist/esm/logger.js",
            "require": "./dist/cjs/logger.js",
            "types": "./dist/types/logger.d.ts"
        },
        "./markup": {
            "import": "./dist/esm/markup.js",
            "require": "./dist/cjs/markup.js",
            "types": "./dist/types/markup.d.ts"
        },
        "./menu": {
            "import": "./dist/esm/menu.js",
            "require": "./dist/cjs/menu.js",
            "types": "./dist/types/menu.d.ts"
        },
        "./plugin": {
            "import": "./dist/esm/plugin.js",
            "require": "./dist/cjs/plugin.js",
            "types": "./dist/types/plugin.d.ts"
        },
        "./queue": {
            "import": "./dist/esm/queue.js",
            "require": "./dist/cjs/queue.js",
            "types": "./dist/types/queue.d.ts"
        },
        "./ratelimit": {
            "import": "./dist/esm/ratelimit.js",
            "require": "./dist/cjs/ratelimit.js",
            "types": "./dist/types/ratelimit.d.ts"
        },
        "./scene": {
            "import": "./dist/esm/scene.js",
            "require": "./dist/cjs/scene.js",
            "types": "./dist/types/scene.d.ts"
        },
        "./session": {
            "import": "./dist/esm/session.js",
            "require": "./dist/cjs/session.js",
            "types": "./dist/types/session.d.ts"
        },
        "./types": {
            "import": "./dist/esm/types.js",
            "require": "./dist/cjs/types.js",
            "types": "./dist/types/types.d.ts"
        },
        "./webapp": {
            "import": "./dist/esm/webapp.js",
            "require": "./dist/cjs/webapp.js",
            "types": "./dist/types/webapp.d.ts"
        },
        "./wizard": {
            "import": "./dist/esm/wizard.js",
            "require": "./dist/cjs/wizard.js",
            "types": "./dist/types/wizard.d.ts"
        }
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "sideEffects": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alfandi09/vibegram.git"
    },
    "bugs": {
        "url": "https://github.com/alfandi09/vibegram/issues"
    },
    "homepage": "https://alfandi09.github.io/vibegram/",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "clean": "node scripts/clean-dist.js",
        "build:cjs": "tsc",
        "build:esm": "tsc --project tsconfig.esm.json",
        "build": "npm run clean && npm run build:cjs && npm run build:esm && node scripts/postbuild.js",
        "build:watch": "tsc --watch",
        "prepublishOnly": "npm run build && npm test",
        "typecheck": "tsc --noEmit",
        "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
        "typecheck:examples": "tsc --project tsconfig.examples.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write src/**/*.ts",
        "docs:api": "typedoc",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "pack:dry": "npm pack --dry-run"
    },
    "keywords": [
        "telegram",
        "bot",
        "api",
        "vibegram",
        "bot-api",
        "framework",
        "telegram-bot",
        "middleware",
        "typescript",
        "webhook",
        "conversation",
        "session",
        "pagination"
    ],
    "author": "Alfa",
    "license": "ISC",
    "dependencies": {
        "axios": "1.15.0",
        "form-data": "^4.0.5"
    },
    "overrides": {
        "follow-redirects": "1.16.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.4",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/coverage-v8": "^3.2.4",
        "@vueuse/core": "^14.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "eslint": "^9.39.4",
        "lucide-vue-next": "^1.0.0",
        "prettier": "^3.8.2",
        "reka-ui": "^2.9.6",
        "shadcn-vue": "^2.6.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.4",
        "ts-node": "^10.9.2",
        "tw-animate-css": "^1.4.0",
        "typedoc": "^0.28.0",
        "typescript": "^6.0.2",
        "vitepress": "^1.6.4",
        "vitest": "^3.2.4",
        "vue": "^3.5.32"
    }
}
